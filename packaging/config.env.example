# CyberPower UPS Monitoring Service Configuration
# 
# Copy this file to /etc/ups-monitor/config.env and customize for your environment.
# The service will load these environment variables on startup.
# 
# Permissions: sudo chown root:ups-monitor config.env && sudo chmod 0640 config.env

# === HTTP Server Configuration (for ups-monitor service) ===

# Port to listen on for HTTP API and Prometheus metrics
# Default: 9999
# LISTEN_PORT=9999

# Host to bind to
# Default: 0.0.0.0 (listen on all interfaces)
# LISTEN_HOST=0.0.0.0

# === Prometheus Metrics ===

# Enable Prometheus metrics export (true/false)
# Default: true
# PROMETHEUS_ENABLED=true

# Metrics endpoint path
# Default: /metrics
# PROMETHEUS_PATH=/metrics

# === UPS Monitoring ===

# Polling interval in seconds (how often to check UPS status)
# Default: 10
# MONITOR_INTERVAL=10

# Logging level: debug, info, warn, error
# Default: info
# LOG_LEVEL=info

# === Advanced ===

# USB device serial number to monitor (leave blank to auto-detect first device)
# Default: (auto-detect)
# UPS_SERIAL=

# Maximum connections to HTTP server
# Default: 100
# MAX_CONNECTIONS=100
